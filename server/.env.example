# MySQL
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_PORT=3306
MYSQL_DATABASE=myblog

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT
JWT_SECRET=your_jwt_secret

# Crypto (用于密码MD5加盐)
CRYPTO_SECRET_KEY="your_secret_key#with_hash"

